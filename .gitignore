logs/
*.log
npm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj

# Coverage
coverage/
.nyc_output/

